        "# ============================================================\n",
        "# セル6.5: メタディスクリプション・タグ自動生成\n",
        "# ============================================================\n",
        "\n",
        "def generate_meta_and_tags(title, keyword, article_html):\n",
        "    plain_text = re.sub(r'<[^>]+>', ' ', article_html)[:2000]\n",
        "\n",
        "    prompt = (\n",
        "        f'You are an SEO specialist. Based on this article, generate:\\n'\n",
        "        f'1. A meta description (140-155 characters, must include \"{keyword}\", '\n",
        "        f'ends with intriguing hook or mild CTA)\\n'\n",
        "        f'2. 5-7 relevant tags (lowercase, comma-separated)\\n\\n'\n",
        "        f'Title: {title}\\n'\n",
        "        f'Keyword: {keyword}\\n'\n",
        "        f'Article excerpt: {plain_text}\\n\\n'\n",
        "        'Respond ONLY in this exact JSON format, no markdown, no code fences:\\n'\n",
        "        '{\"meta_description\": \"...\", \"tags\": [\"tag1\", \"tag2\", \"tag3\"]}'\n",
        "    )\n",
        "\n",
        "    try:\n",
        "        response = gemini_client.models.generate_content(\n",
        "            model='gemini-2.5-flash',\n",
        "            contents=prompt\n",
        "        )\n",
        "        raw = response.text.strip().replace('```json', '').replace('```', '').strip()\n",
        "        data = json.loads(raw)\n",
        "\n",
        "        meta = data.get('meta_description', '').strip()\n",
        "        tags = data.get('tags', [])\n",
        "\n",
        "        if len(meta) > 160:\n",
        "            meta = meta[:155].rsplit(' ', 1)[0] + '...'\n",
        "\n",
        "        print(f'  ✅ メタディスクリプション生成（{len(meta)}文字）')\n",
        "        print(f'  ✅ タグ生成: {\", \".join(tags)}')\n",
        "        return meta, tags\n",
        "\n",
        "    except Exception as e:\n",
        "        print(f'  ⚠️ メタ生成エラー: {e}')\n",
        "        fallback_meta = f'Discover {keyword} — a Yokohama-based guide to authentic Japanese products worth buying.'\n",
        "        return fallback_meta[:155], [keyword]\n",
        "\n",
        "def get_or_create_tag_ids(tag_names, wp_credentials):\n",
        "    \"\"\"タグ名のリストをWPタグIDのリストに変換（存在しない場合は新規作成）\"\"\"\n",
        "    tag_ids = []\n",
        "    headers = {\n",
        "        'Authorization': f'Basic {wp_credentials}',\n",
        "        'Content-Type': 'application/json'\n",
        "    }\n",
        "\n",
        "    for tag_name in tag_names:\n",
        "        tag_name = tag_name.strip().lower()\n",
        "        if not tag_name:\n",
        "            continue\n",
        "\n",
        "        search_url = f'{WP_URL}/wp-json/wp/v2/tags?search={tag_name}'\n",
        "        res = requests.get(search_url, headers=headers)\n",
        "        existing = res.json() if res.status_code == 200 else []\n",
        "\n",
        "        matched = next((t for t in existing if t['name'].lower() == tag_name), None)\n",
        "\n",
        "        if matched:\n",
        "            tag_ids.append(matched['id'])\n",
        "        else:\n",
        "            create_res = requests.post(\n",
        "                f'{WP_URL}/wp-json/wp/v2/tags',\n",
        "                headers=headers,\n",
        "                json={'name': tag_name}\n",
        "            )\n",
        "            if create_res.status_code in [200, 201]:\n",
        "                tag_ids.append(create_res.json().get('id'))\n",
        "\n",
        "    return tag_ids\n",
        "\n",
        "print('✅ メタ・タグ生成関数準備完了')\n"
      ],

        "\n",
        "def generate_thumbnail(topic_title, keyword):\n",
        "    from google import genai\n",
        "    from google.genai import types\n",
        "\n",
        "    prompt = (\n",
        "        f'Product photography of {keyword}, '\n",
        "        'clean white background, studio lighting, '\n",
        "        'Japanese tableware aesthetic, high detail, '\n",
        "        'sharp focus, 16:9 composition, '\n",
        "        'no text, no watermark, photorealistic'\n",
        "    )\n",
        "    print(f'  🎨 画像生成中: \"{prompt[:60]}...\"')\n",
        "\n",
        "    try:\n",
        "        client = genai.Client(api_key=GEMINI_API_KEY)\n",
        "        response = client.models.generate_images(\n",
        "            model='imagen-4.0-generate-001',\n",
        "            prompt=prompt,\n",
        "            config=types.GenerateImagesConfig(\n",
        "                number_of_images=1,\n",
        "                aspect_ratio='16:9',\n",
        "            )\n",
        "        )\n",
        "        image_bytes = response.generated_images[0].image.image_bytes\n",
        "        print(f'  ✅ 画像生成完了（{len(image_bytes):,} bytes）')\n",
        "        return image_bytes\n",
        "\n",
        "    except Exception as e:\n",
        "        print(f'  ⚠️ 画像生成エラー: {e}')\n",
        "        return None\n",
        "\n",
        "def upload_thumbnail_to_wp(image_bytes, filename, wp_credentials):\n",
        "    upload_url = f'{WP_URL}/wp-json/wp/v2/media'\n",
        "    headers = {\n",
        "        'Authorization': f'Basic {wp_credentials}',\n",
        "        'Content-Disposition': f'attachment; filename=\"{filename}\"',\n",
        "        'Content-Type': 'image/jpeg',\n",
        "    }\n",
        "    res = requests.post(upload_url, headers=headers, data=image_bytes)\n",
        "\n",
        "    if res.status_code == 201:\n",
        "        media_id = res.json().get('id')\n",
        "        media_url = res.json().get('source_url', '')\n",
        "        print(f'  ✅ 画像アップロード完了 (ID: {media_id})')\n",
        "        print(f'     {media_url}')\n",
        "        return media_id\n",
        "    else:\n",
        "        print(f'  ⚠️ 画像アップロード失敗: {res.status_code}')\n",
        "        return None\n",

       # ============================================================
# セル4（差し替え版）: Etsy アフィリエイトリンク生成（Awin経由）
# ------------------------------------------------------------
# 旧版はAmazonタグ方式だったが、Amazon Associatesが未承認のため使用不可。
# 稼働中の Awin UK（Etsy広告主）経由の deeplink を生成する方式に変更する。
# Awinはタグ付与方式ではなく、cread.php形式のdeeplinkが必須。
# ============================================================
import re
import urllib.parse

# --- Awin管理画面から取得して設定（必ず差し替えること） ---
# Account > Profile で確認できる自分のPublisher ID
AWIN_AFFILIATE_ID = "REPLACE_ME"   # 例: "1234567"
# Advertisers でEtsyを開いた際のAdvertiser ID（= Merchant ID）
ETSY_AWIN_MID     = "REPLACE_ME"   # 例: "12345"


def build_awin_deeplink(destination_url: str) -> str:
    """Awinのトラッキングリンク(deeplink)を生成する。
    意図: マーケットプレイス(Etsy)の検索URLをラップすることで、
    個別商品が売り切れてもリンク切れにならない堅牢な導線にする。"""
    encoded = urllib.parse.quote(destination_url, safe="")
    return (
        "https://www.awin1.com/cread.php?"
        f"awinmid={ETSY_AWIN_MID}&awinaffid={AWIN_AFFILIATE_ID}&ued={encoded}"
    )


def etsy_search_url(query: str) -> str:
    """Etsyの検索結果URLを生成する（deeplinkのリンク先として使う）。"""
    q = urllib.parse.quote_plus(query)
    return f"https://www.etsy.com/search?q={q}"


def inject_etsy_links(article_html: str, product_queries: list) -> str:
    """記事HTML内の [PRODUCT LINK HERE] を Awin経由のEtsyリンクで順に置換する。

    product_queries: 各プレースホルダーに対応するEtsy検索キーワードのリスト。
                     例: ["Hasami ware mamezara", "Mino ware mamezara set", ...]
    """
    if not product_queries:
        return article_html

    placeholders = re.findall(r"\[PRODUCT LINK HERE\]", article_html)
    if not placeholders:
        print("  ⚠️ プレースホルダー [PRODUCT LINK HERE] が見つかりません")
        return article_html

    # 意図: ID未設定のまま本番リンクを生成して収益を取りこぼす事故を防ぐ
    if "REPLACE_ME" in (AWIN_AFFILIATE_ID, ETSY_AWIN_MID):
        raise ValueError(
            "AWIN_AFFILIATE_ID と ETSY_AWIN_MID を実IDに差し替えてください"
        )

    print(f"  📎 プレースホルダー {len(placeholders)}個 → Etsy(Awin)リンクで置換")
    for i in range(len(placeholders)):
        query = product_queries[min(i, len(product_queries) - 1)]
        deeplink = build_awin_deeplink(etsy_search_url(query))
        anchor = (
            f'<a href="{deeplink}" target="_blank" rel="sponsored noopener">'
            "Check current price and availability on Etsy</a>"
        )
        article_html = article_html.replace("[PRODUCT LINK HERE]", anchor, 1)

    return article_html


# ============================================================
# 楽天市場API：商品検索 → アフィリエイトリンク生成
# ============================================================

def get_amazon_affiliate_links(keyword: str, num_products=5):
    if not RAKUTEN_APP_ID:
        print("❌ RAKUTEN_APP_ID が設定されていません")
        return []

    api_url = "https://app.rakuten.co.jp/services/api/IchibaItem/Search/20220601"
    params = {
        'applicationId': RAKUTEN_APP_ID,
        'affiliateId': RAKUTEN_AFFILIATE_ID,
        'keyword': keyword,
        'hits': num_products,
        'sort': '-reviewCount',
        'imageFlag': 1,
    }

    try:
        res = requests.get(api_url, params=params, timeout=10)
        if res.status_code != 200:
            print(f"⚠️  楽天API エラー {res.status_code}: {res.text[:200]}")
            return []

        data = res.json()
        items = data.get('Items', [])

        links = []
        for item in items[:num_products]:
            product = item.get('Item', {})
            links.append({
                'title': product.get('itemName', 'Product'),
                'url':   product.get('affiliateUrl', product.get('itemUrl', '')),
                'price': f"¥{product.get('itemPrice', 0):,}",
            })

        print(f"   ✅ 楽天: {len(links)}件取得")
        return links

    except Exception as e:
        print(f"❌ 楽天API例外: {e}")
        return []


def inject_rakuten_links(article_html: str, rakuten_links: list) -> str:
    if not rakuten_links:
        print("   ⚠️  リンクなし → プレースホルダー削除")
        return article_html.replace('[PRODUCT LINK HERE]', '')

    updated_html = article_html
    for link in rakuten_links:
        if '[PRODUCT LINK HERE]' not in updated_html:
            break
        html_link = (
            f'<a href="{link["url"]}" rel="sponsored noopener" target="_blank">'
            f'{link["title"]} ({link["price"]})</a>'
        )
        updated_html = updated_html.replace('[PRODUCT LINK HERE]', html_link, 1)

    count = article_html.count('[PRODUCT LINK HERE]') - updated_html.count('[PRODUCT LINK HERE]')
    print(f"   ✅ 楽天リンク: {count}個挿入")
    return updated_html


print("✅ Etsy(Awin) + 楽天アフィリエイト関数 準備完了")
